<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_type_pill"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp"
            android:text="Flashcard"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:textAppearance="@style/TextAppearance.LIL.LabelLarge" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/flashcard_prompt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.LIL.HeadlineMedium"
                    tools:text="What is Linux and why is it important?" />

                <LinearLayout
                    android:id="@+id/flashcard_reveal_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="16dp"
                        android:background="?attr/colorOutlineVariant" />

                    <TextView
                        android:id="@+id/flashcard_answer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textColor="?attr/colorPrimary"
                        android:textStyle="bold"
                        android:textAppearance="@style/TextAppearance.LIL.BodyLarge"
                        tools:text="An open-source Unix-like OS kernel" />

                    <TextView
                        android:id="@+id/flashcard_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:visibility="gone"
                        android:textAppearance="@style/TextAppearance.LIL.BodyMedium" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_show_answer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Show Answer"
            app:cornerRadius="12dp" />

        <TextView
            android:id="@+id/flashcard_did_you_get_it"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="Did you get it?"
            android:visibility="gone"
            android:textAppearance="@style/TextAppearance.LIL.BodyMedium" />

        <LinearLayout
            android:id="@+id/flashcard_grade_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_missed"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="❌ Missed it"
                android:textColor="@color/incorrect_red"
                app:strokeColor="@color/incorrect_red" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_got_it"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="✅ Got it!"
                android:backgroundTint="@color/correct_green" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>

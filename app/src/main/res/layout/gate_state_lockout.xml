<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔒"
        android:textSize="64sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Locked"
        android:textColor="@color/lockout_purple"
        android:textStyle="bold"
        android:textAppearance="@style/TextAppearance.LIL.HeadlineMedium" />

    <TextView
        android:id="@+id/lockout_countdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:textColor="@color/lockout_purple"
        android:textStyle="bold"
        android:textSize="48sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Come back when the timer ends."
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textAppearance="@style/TextAppearance.LIL.BodyMedium" />

</LinearLayout>
